{
  "uid": "pulse-cubrid-7p",
  "title": "Pulse - CUBRID (7 panels)",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["pulse", "cubrid"],
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "broker_mode",
        "type": "custom",
        "label": "BROKER MODE",
        "query": "REALTIME : _1s$, CUMULATIVE : $",
        "options": [],
        "current": { "text": "REALTIME", "value": "_1s$" }
      },
      {
        "name": "broker",
        "type": "query",
        "datasource": "Prometheus",
        "refresh": 2,
        "query": {
          "query": "label_values({__name__=~\"pulse_cubrid_broker_tps(_1s)?\"}, broker)",
          "refId": "var-broker"
        },
        "label": "BROKER",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": false, "text": "ALL", "value": ".*" }
      },
      {
        "name": "db",
        "type": "query",
        "datasource": "Prometheus",
        "refresh": 2,
        "query": {
          "query": "label_values(pulse_cubrid_tran_sessions, db)",
          "refId": "var-db"
        },
        "label": "DB",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": false, "text": "ALL", "value": ".*" }
      },
      {
        "name": "node",
        "type": "query",
        "datasource": "Prometheus",
        "refresh": 2,
        "query": {
          "query": "label_values(pulse_cubrid_ha_role, node)",
          "refId": "var-node"
        },
        "label": "NODE",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": false, "text": "ALL", "value": ".*" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CONNECTIONS (SESSIONS)",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "pulse_cubrid_tran_sessions{db=~\"$db\"}",
          "legendFormat": "SESSIONS {{db}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "TPS / QPS (BROKER STATUS)",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "{__name__=~\"pulse_cubrid_broker_tps${broker_mode:raw}\",broker=~\"$broker\"}",
          "legendFormat": "TPS {{broker}}:{{port}}"
        },
        {
          "refId": "B",
          "expr": "{__name__=~\"pulse_cubrid_broker_qps${broker_mode:raw}\",broker=~\"$broker\"}",
          "legendFormat": "QPS {{broker}}:{{port}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "LOCKS / WAITS (TRANLIST)",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "pulse_cubrid_tran_lock_wait{db=~\"$db\"}",
          "legendFormat": "LOCK_WAIT {{db}}"
        },
        {
          "refId": "B",
          "expr": "pulse_cubrid_tran_active{db=~\"$db\"}",
          "legendFormat": "ACTIVE {{db}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "ERRORS (BROKER STATUS)",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "pulse_cubrid_broker_err_query_count{broker=~\"$broker\"}",
          "legendFormat": "ERR {{broker}}:{{port}}"
        },
        {
          "refId": "B",
          "expr": "pulse_cubrid_broker_unique_err_query_count{broker=~\"$broker\"}",
          "legendFormat": "UNIQUE_ERR {{broker}}:{{port}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "LONGEST QUERY / TRAN (SECONDS)",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "refId": "A",
          "expr": "pulse_cubrid_tran_longest_query_seconds{db=~\"$db\"}",
          "legendFormat": "QUERY {{db}}"
        },
        {
          "refId": "B",
          "expr": "pulse_cubrid_tran_longest_tran_seconds{db=~\"$db\"}",
          "legendFormat": "TRAN {{db}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "SPACE USAGE (PERMANENT) %",
      "gridPos": { "x": 0, "y": 16, "w": 16, "h": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * pulse_cubrid_space_used_bytes{db=~\"$db\",type=\"PERMANENT\"} / pulse_cubrid_space_total_bytes{db=~\"$db\",type=\"PERMANENT\"}",
          "legendFormat": "USED_PCT {{db}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "HA ROLE (1=MASTER, 0=SLAVE)",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 8 },
      "datasource": "Prometheus",
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "SLAVE" },
                "1": { "text": "MASTER" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "pulse_cubrid_ha_role{node=~\"$node\"}",
          "legendFormat": "ROLE {{node}}"
        }
      ]
    }
  ]
}

